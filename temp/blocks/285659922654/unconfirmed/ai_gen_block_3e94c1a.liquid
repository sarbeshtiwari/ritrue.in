{% doc %}
  @prompt
    Create Buy Now button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-buy-now-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-buy-now-button-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-buy-now-button-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-buy-now-button-element-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.button_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 {{ block.settings.shadow_vertical_offset }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-buy-now-button-element-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
    box-shadow: 0 {{ block.settings.shadow_vertical_offset | plus: 2 }}px {{ block.settings.shadow_blur | plus: 5 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 1.2 }});
  }

  .ai-buy-now-button-element-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .ai-buy-now-button-icon-{{ ai_gen_id }} {
    width: {{ block.settings.font_size }}px;
    height: {{ block.settings.font_size }}px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-buy-now-button-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-buy-now-button-element-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding | times: 0.9 }}px {{ block.settings.button_padding | times: 1.3 }}px;
    }
  }
{% endstyle %}

<buy-now-button-{{ ai_gen_id }} class="ai-buy-now-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-buy-now-button-container-{{ ai_gen_id }}">
    <div class="ai-buy-now-button-wrapper-{{ ai_gen_id }}">
      <button
        type="button"
        class="ai-buy-now-button-element-{{ ai_gen_id }}"
        data-product-id="{{ product.id }}"
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      >
        {% if block.settings.show_icon %}
          <svg class="ai-buy-now-button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        {% endif %}
        <span>{{ block.settings.button_text }}</span>
      </button>
    </div>
  </div>
</buy-now-button-{{ ai_gen_id }}>

<script>
  (function() {
    class BuyNowButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.button = this.querySelector('.ai-buy-now-button-element-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.button) {
          this.button.addEventListener('click', this.handleBuyNow.bind(this));
        }
      }

      handleBuyNow(event) {
        event.preventDefault();
        
        const button = event.currentTarget;
        const variantId = button.dataset.variantId;
        
        if (!variantId) {
          console.error('No variant ID found');
          return;
        }

        button.disabled = true;
        const originalText = button.querySelector('span').textContent;
        button.querySelector('span').textContent = '{{ block.settings.loading_text }}';

        const formData = {
          items: [{
            id: variantId,
            quantity: 1
          }]
        };

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/checkout';
        })
        .catch((error) => {
          console.error('Error:', error);
          button.disabled = false;
          button.querySelector('span').textContent = originalText;
          alert('There was an error processing your request. Please try again.');
        });
      }

      disconnectedCallback() {
        if (this.button) {
          this.button.removeEventListener('click', this.handleBuyNow.bind(this));
        }
      }
    }

    customElements.define('buy-now-button-{{ ai_gen_id }}', BuyNowButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Buy now button",
  "settings": [
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Buy it now"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading text",
      "default": "Processing..."
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#9b046f"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#fdfbf7"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#2e2a39"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#fdfbf7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Shadow"
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "range",
      "id": "shadow_vertical_offset",
      "label": "Vertical offset",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Blur",
      "min": 0,
      "max": 20,
      "step": 5,
      "unit": "px",
      "default": 5
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Buy now button"
    }
  ]
}
{% endschema %}
