{% render 'ritrue-section-styles', section: section %}
<div class="ritrue-trust-section">
  <div class="ritrue-container">
    <h2 class="ritrue-section-heading">{{ section.settings.heading }}</h2>

    <div class="ritrue-trust-section__grid">
      {%- for block in section.blocks -%}
        <div class="ritrue-trust-point ritrue-reveal" {{ block.shopify_attributes }}>
          <div class="ritrue-trust-point__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {%- case block.settings.icon -%}
                {%- when 'shield-check' -%}
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
                {%- when 'leaf' -%}
                  <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L7 18"/><path d="M2 2s7.6 4.35 12 8c3.2 2.66 5.33 5.7 5.33 5.7"/>
                {%- when 'heart' -%}
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                {%- when 'printer' -%}
                  <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                {%- else -%}
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              {%- endcase -%}
            </svg>
          </div>
          <h3 class="ritrue-trust-point__title">{{ block.settings.title }}</h3>
          <p class="ritrue-trust-point__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "RITRUE Trust Points",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY TRUST RITRUE?"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background Color",
      "info": "Leave empty to use default."
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Background Image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "label": "Minimum Height (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 for auto height."
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "Content Font Size (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 to use default size."
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust Point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield-check", "label": "Shield Check (Safe)" },
            { "value": "leaf", "label": "Leaf (Natural)" },
            { "value": "heart", "label": "Heart (Cruelty Free)" },
            { "value": "printer", "label": "Printer (Soy Ink)" }
          ],
          "default": "shield-check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Safe & Effective"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every ingredient is carefully selected and tested for safety and efficacy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RITRUE Trust Points",
      "blocks": [
        {
          "type": "trust_point",
          "settings": {
            "icon": "shield-check",
            "title": "Safe & Effective",
            "description": "Every ingredient is carefully selected and tested for safety and efficacy."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "leaf",
            "title": "No Harmful Chemicals",
            "description": "Free from parabens, sulphates, and other harmful chemicals."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "heart",
            "title": "Cruelty Free",
            "description": "Never tested on animals. We believe in ethical beauty."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "printer",
            "title": "Printed with Soy Ink",
            "description": "Our packaging uses eco-friendly soy-based inks."
          }
        }
      ]
    }
  ]
}
{% endschema %}
