{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pdp-about-tabs {
    background: {{ section.settings.background_color }};
  }

  .pdp-about-tabs__heading {
    text-align: center;
    margin-bottom: 2.4rem;
    font-size: 2.4rem;
    font-weight: 600;
    color: #1e1e1e;
  }

  .pdp-about-tabs__nav {
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 2px solid #eaeaea;
    margin-bottom: 3.2rem;
    list-style: none;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pdp-about-tabs__nav::-webkit-scrollbar {
    display: none;
  }

  .pdp-about-tabs__tab {
    padding: 1.2rem 2.4rem;
    font-size: 1.4rem;
    font-weight: 500;
    color: #737373;
    cursor: pointer;
    border: none;
    background: transparent;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    font-family: var(--font-body-family), sans-serif;
  }

  .pdp-about-tabs__tab:hover {
    color: #1e1e1e;
  }

  .pdp-about-tabs__tab.is-active {
    color: #1e1e1e;
    font-weight: 600;
    border-bottom-color: #E85A28;
  }

  .pdp-about-tabs__panel {
    display: none;
  }

  .pdp-about-tabs__panel.is-active {
    display: block;
  }

  .pdp-about-tabs__image {
    border-radius: 1.2rem;
    overflow: hidden;
    max-width: 100%;
  }

  .pdp-about-tabs__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .pdp-about-tabs__image--desktop {
    display: block;
  }

  .pdp-about-tabs__image--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .pdp-about-tabs__image--desktop {
      display: none;
    }

    .pdp-about-tabs__image--mobile {
      display: block;
    }

    .pdp-about-tabs__tab {
      padding: 1rem 1.6rem;
      font-size: 1.2rem;
    }
  }
{%- endstyle -%}

<div class="pdp-about-tabs section-{{ section.id }}-padding">
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.heading != blank -%}
      <h2 class="pdp-about-tabs__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <pdp-tabs-component data-section-id="{{ section.id }}">
        <div class="pdp-about-tabs__nav" role="tablist">
          {%- for block in section.blocks -%}
            <button
              class="pdp-about-tabs__tab{% if forloop.first %} is-active{% endif %}"
              role="tab"
              aria-selected="{{ forloop.first }}"
              aria-controls="TabPanel-{{ section.id }}-{{ forloop.index }}"
              id="Tab-{{ section.id }}-{{ forloop.index }}"
              data-tab-index="{{ forloop.index }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.tab_label }}
            </button>
          {%- endfor -%}
        </div>

        {%- for block in section.blocks -%}
          <div
            class="pdp-about-tabs__panel{% if forloop.first %} is-active{% endif %}"
            role="tabpanel"
            id="TabPanel-{{ section.id }}-{{ forloop.index }}"
            aria-labelledby="Tab-{{ section.id }}-{{ forloop.index }}"
            data-panel-index="{{ forloop.index }}"
            tabindex="0"
          >
            {%- if block.settings.desktop_image != blank -%}
              <div class="pdp-about-tabs__image pdp-about-tabs__image--desktop">
                {{ block.settings.desktop_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 800, 1000, 1200', sizes: '(min-width: 750px) 1200px, 100vw' }}
              </div>
            {%- endif -%}
            {%- if block.settings.mobile_image != blank -%}
              <div class="pdp-about-tabs__image pdp-about-tabs__image--mobile">
                {{ block.settings.mobile_image | image_url: width: 750 | image_tag: loading: 'lazy', widths: '375, 500, 750', sizes: '100vw' }}
              </div>
            {%- elsif block.settings.desktop_image != blank -%}
              <div class="pdp-about-tabs__image pdp-about-tabs__image--mobile">
                {{ block.settings.desktop_image | image_url: width: 750 | image_tag: loading: 'lazy', widths: '375, 500, 750', sizes: '100vw' }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </pdp-tabs-component>

      <script>
        if (!customElements.get('pdp-tabs-component')) {
          class PdpTabsComponent extends HTMLElement {
            constructor() {
              super();
            }

            connectedCallback() {
              this.tabs = this.querySelectorAll('[role="tab"]');
              this.panels = this.querySelectorAll('[role="tabpanel"]');

              this.tabs.forEach((tab) => {
                tab.addEventListener('click', this.handleTabClick.bind(this));
              });
            }

            handleTabClick(event) {
              const clickedTab = event.currentTarget;
              const index = clickedTab.dataset.tabIndex;

              this.tabs.forEach((tab) => {
                tab.classList.remove('is-active');
                tab.setAttribute('aria-selected', 'false');
              });

              this.panels.forEach((panel) => {
                panel.classList.remove('is-active');
              });

              clickedTab.classList.add('is-active');
              clickedTab.setAttribute('aria-selected', 'true');

              const targetPanel = this.querySelector(`[data-panel-index="${index}"]`);
              if (targetPanel) {
                targetPanel.classList.add('is-active');
              }
            }
          }
          customElements.define('pdp-tabs-component', PdpTabsComponent);
        }
      </script>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP About Tabs",
  "class": "pdp-about-tabs-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All About This Product"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab heading",
          "default": "Tab"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP About Tabs",
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "What Makes It Unique" } },
        { "type": "tab", "settings": { "tab_label": "Product Journey" } },
        { "type": "tab", "settings": { "tab_label": "What You'll Love" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
