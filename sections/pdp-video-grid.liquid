{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pdp-video-grid {
    background: {{ section.settings.background_color }};
  }

  .pdp-video-grid__heading {
    text-align: center;
    margin-bottom: 3.2rem;
    font-size: 2.4rem;
    font-weight: 400;
    color: #57413F;
    font-family: 'Amiri', serif;
  }

  .pdp-video-grid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .pdp-video-grid__grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .pdp-video-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .pdp-video-grid__item {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: 9 / 16;
    background: #F5F0E8;
  }

  .pdp-video-grid__item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pdp-video-grid__item-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.2rem;
    background: linear-gradient(transparent, rgba(86, 64, 63, 0.7));
    color: #FEF4E4;
    font-family: 'Amiri', serif;
    font-size: 1.3rem;
    font-style: italic;
    text-align: center;
  }
{%- endstyle -%}

<div class="pdp-video-grid section-{{ section.id }}-padding">
  {% render 'ritrue-section-styles', section: section %}
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.heading != blank -%}
      <h2 class="pdp-video-grid__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="pdp-video-grid__grid" role="list">
        {%- for block in section.blocks -%}
          <li class="pdp-video-grid__item" {{ block.shopify_attributes }}>
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
            {%- elsif block.settings.video_url != blank -%}
              <video autoplay loop muted playsinline>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- else -%}
              <div style="width:100%;height:100%;background:#F5F0E8;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.8rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C4AE78" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="0" ry="0"></rect></svg>
                <span style="font-family:'Amiri',serif;font-size:1.1rem;color:#8A7A70;font-style:italic;">Upload Video</span>
              </div>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <div class="pdp-video-grid__item-caption">{{ block.settings.caption }}</div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP Video Grid",
  "class": "pdp-video-grid-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See It In Action"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFAEF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Custom background color"
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Custom background image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "min": 0,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 0
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Content font size",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video",
      "limit": 6,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "External video URL (mp4 fallback)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Video Grid",
      "blocks": [
        { "type": "video_item", "settings": { "caption": "Application" } },
        { "type": "video_item", "settings": { "caption": "15-Minute Wait" } },
        { "type": "video_item", "settings": { "caption": "The Reveal" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
