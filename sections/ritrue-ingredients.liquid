{% render 'ritrue-section-styles', section: section %}
<div id="ingredients" class="ritrue-ingredients">
  <div class="ritrue-container">
    <h2 class="ritrue-section-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="ritrue-section-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="ritrue-ingredients__grid">
      {%- for block in section.blocks -%}
        <div class="ritrue-ingredient-card ritrue-reveal" {{ block.shopify_attributes }}>
          <div class="ritrue-ingredient-card__img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.name | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {%- else -%}
              <div style="width:100%;height:100%;background:var(--ritrue-warm-bg,#F7F1E8);display:flex;align-items:center;justify-content:center;">{{ 'image' | placeholder_svg_tag }}</div>
            {%- endif -%}
          </div>
          <div class="ritrue-ingredient-card__body">
            <h3 class="ritrue-ingredient-card__name">{{ block.settings.name }}</h3>
            <p class="ritrue-ingredient-card__desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "RITRUE Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE POWER OF MOROCCAN NILA"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ancient Moroccan ingredients backed by modern science"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background Color",
      "info": "Leave empty to use default."
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Background Image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "label": "Minimum Height (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 for auto height."
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "Content Font Size (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 to use default size."
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name",
          "default": "Moroccan Nila"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A treasured Moroccan blue powder known for its powerful skin-brightening and tan-removing properties."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RITRUE Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Moroccan Nila",
            "description": "A treasured Moroccan blue powder known for its powerful skin-brightening and tan-removing properties."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Alpha Arbutin",
            "description": "A gold-standard brightening agent that fades dark spots and evens out skin tone without irritation."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Niacinamide",
            "description": "Vitamin B3 powerhouse that minimizes pores, reduces inflammation, and strengthens the skin barrier."
          }
        }
      ]
    }
  ]
}
{% endschema %}
