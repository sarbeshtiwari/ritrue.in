{{ 'ritrue-before-after.css' | asset_url | stylesheet_tag }}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

{% render 'ritrue-section-styles', section: section %}

<div class="pdp-ba section-{{ section.id }}-padding" style="background:{{ section.settings.background_color }};">
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.heading != blank -%}
      <h2 class="pdp-ba__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="pdp-ba__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="pdp-ba__grid pdp-ba__grid--cols-{{ section.settings.columns }}">
        {%- for block in section.blocks -%}
          <div class="pdp-ba__item" {{ block.shopify_attributes }}>
            <ba-slider class="pdp-ba__slider pdp-ba__slider--{{ section.settings.image_ratio_key }}">
              <div class="pdp-ba__spacer">&nbsp;</div>
              <div class="pdp-ba__layer pdp-ba__layer--after">
                {%- if block.settings.after_image != blank -%}
                  <img
                    src="{{ block.settings.after_image | image_url: width: 800 }}"
                    srcset="{{ block.settings.after_image | image_url: width: 400 }} 400w, {{ block.settings.after_image | image_url: width: 600 }} 600w, {{ block.settings.after_image | image_url: width: 800 }} 800w"
                    sizes="(min-width: 750px) 500px, 90vw"
                    alt="{{ block.settings.after_label | default: 'After' }}"
                    loading="lazy"
                    width="{{ block.settings.after_image.width }}"
                    height="{{ block.settings.after_image.height }}"
                  >
                {%- else -%}
                  <div class="pdp-ba__placeholder">Upload After Image</div>
                {%- endif -%}
              </div>
              <div class="pdp-ba__layer pdp-ba__layer--before">
                {%- if block.settings.before_image != blank -%}
                  <img
                    src="{{ block.settings.before_image | image_url: width: 800 }}"
                    srcset="{{ block.settings.before_image | image_url: width: 400 }} 400w, {{ block.settings.before_image | image_url: width: 600 }} 600w, {{ block.settings.before_image | image_url: width: 800 }} 800w"
                    sizes="(min-width: 750px) 500px, 90vw"
                    alt="{{ block.settings.before_label | default: 'Before' }}"
                    loading="lazy"
                    width="{{ block.settings.before_image.width }}"
                    height="{{ block.settings.before_image.height }}"
                  >
                {%- else -%}
                  <div class="pdp-ba__placeholder pdp-ba__placeholder--dark">Upload Before Image</div>
                {%- endif -%}
              </div>
              <div class="pdp-ba__handle" aria-hidden="true">
                <span class="pdp-ba__handle-grip">
                  <svg width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 1L2 7l7 6" stroke="#57413F" stroke-width="1.5"/></svg>
                  <svg width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l7 6-7 6" stroke="#57413F" stroke-width="1.5"/></svg>
                </span>
              </div>
              <span class="pdp-ba__label pdp-ba__label--before">{{ block.settings.before_label | default: 'Before' }}</span>
              <span class="pdp-ba__label pdp-ba__label--after">{{ block.settings.after_label | default: 'After' }}</span>
            </ba-slider>
            {%- if block.settings.caption != blank -%}
              <p class="pdp-ba__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  if (!customElements.get('ba-slider')) {
    class BASlider extends HTMLElement {
      connectedCallback() {
        this.isDragging = false;
        this.beforeLayer = this.querySelector('.pdp-ba__layer--before');
        this.handle = this.querySelector('.pdp-ba__handle');
        if (!this.beforeLayer || !this.handle) return;

        this.addEventListener('mousedown', (e) => { this.isDragging = true; this.update(e); });
        this.addEventListener('touchstart', (e) => { this.isDragging = true; this.update(e); }, { passive: true });

        const onMove = (e) => {
          if (!this.isDragging) return;
          if (e.cancelable) e.preventDefault();
          this.update(e);
        };
        const onEnd = () => { this.isDragging = false; };

        document.addEventListener('mousemove', onMove);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('mouseup', onEnd);
        document.addEventListener('touchend', onEnd);

        this.setPosition(50);
      }

      update(e) {
        const rect = this.getBoundingClientRect();
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const pct = Math.min(Math.max(((clientX - rect.left) / rect.width) * 100, 0), 100);
        this.setPosition(pct);
      }

      setPosition(pct) {
        this.beforeLayer.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
        this.handle.style.left = pct + '%';
      }
    }
    customElements.define('ba-slider', BASlider);
  }
</script>

{% schema %}
{
  "name": "Before & After Slider",
  "class": "pdp-before-after-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real, Instant Transformation!"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Drag to see the difference"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio_key",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "portrait"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFAEF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Custom background color"
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Custom background image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "min": 0,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 0
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Content font size",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Comparison",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before image"
        },
        {
          "type": "text",
          "id": "before_label",
          "label": "Before label",
          "default": "Before"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After image"
        },
        {
          "type": "text",
          "id": "after_label",
          "label": "After label",
          "default": "After"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Before & After Slider",
      "blocks": [
        { "type": "comparison" },
        { "type": "comparison" }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
