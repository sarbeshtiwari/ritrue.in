{% render 'ritrue-section-styles', section: section %}
<div class="ritrue-bottom-strip">
  <div class="ritrue-container">
    <div class="ritrue-bottom-strip__inner">
      {%- for block in section.blocks -%}
        <div class="ritrue-bottom-strip__item" {{ block.shopify_attributes }}>
          <div class="ritrue-bottom-strip__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}
                  <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                {%- when 'refresh' -%}
                  <polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
                {%- when 'lock' -%}
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                {%- when 'headphones' -%}
                  <path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
                {%- else -%}
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              {%- endcase -%}
            </svg>
          </div>
          <div>
            <div class="ritrue-bottom-strip__text">{{ block.settings.title }}</div>
            {%- if block.settings.subtitle != blank -%}
              <div class="ritrue-bottom-strip__subtext">{{ block.settings.subtitle }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "RITRUE Service Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background Color",
      "info": "Leave empty to use default."
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Background Image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "label": "Minimum Height (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 for auto height."
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "Content Font Size (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 to use default size."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "lock", "label": "Lock (Secure)" },
            { "value": "headphones", "label": "Headphones (Support)" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "On prepaid orders"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RITRUE Service Strip",
      "blocks": [
        { "type": "service", "settings": { "icon": "truck", "title": "Free Shipping", "subtitle": "On prepaid orders" } },
        { "type": "service", "settings": { "icon": "refresh", "title": "Easy Returns", "subtitle": "7-day return policy" } },
        { "type": "service", "settings": { "icon": "lock", "title": "Secure Payment", "subtitle": "100% safe checkout" } },
        { "type": "service", "settings": { "icon": "headphones", "title": "Customer Support", "subtitle": "We're here to help" } }
      ]
    }
  ]
}
{% endschema %}
