{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pdp-ingredients {
    background: {{ section.settings.background_color }};
  }

  .pdp-ingredients__heading {
    text-align: center;
    margin-bottom: 4rem;
    font-size: 3.2rem;
    font-weight: 400;
    color: #57413F;
    font-family: 'Amiri', serif;
  }

  .pdp-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .pdp-ingredients__grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
      gap: 2.4rem;
    }
  }

  .pdp-ingredients__card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(46, 42, 57, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    padding: 3.6rem 2.8rem 3.2rem;
    text-align: center;
    border: none;
  }

  .pdp-ingredients__card:hover {
    box-shadow: 0 6px 24px rgba(46, 42, 57, 0.1);
    transform: translateY(-4px);
  }

  .pdp-ingredients__card-image {
    width: 160px;
    height: 160px;
    margin: 0 auto 2.4rem;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid #C4AE78;
    box-shadow: 0 0 0 6px rgba(196, 174, 120, 0.15);
    aspect-ratio: auto;
    background: transparent;
  }

  .pdp-ingredients__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .pdp-ingredients__card:hover .pdp-ingredients__card-image img {
    transform: scale(1.08);
  }

  .pdp-ingredients__card-body {
    padding: 0;
    text-align: center;
  }

  .pdp-ingredients__badge {
    display: inline-block;
    background: {{ section.settings.badge_color }};
    color: #FEF4E4;
    font-size: 1.1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.5rem 1.2rem;
    border-radius: 0;
    margin-bottom: 1.2rem;
    font-family: 'Amiri', serif;
  }

  .pdp-ingredients__card-title {
    font-size: 2.2rem;
    font-weight: 600;
    color: #57413F;
    margin: 0 0 1.2rem;
    line-height: 1.3;
    font-family: 'Amiri', serif;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pdp-ingredients__card-text {
    font-size: 1.5rem;
    color: #57413F;
    opacity: 0.7;
    margin: 0;
    line-height: 1.65;
    font-family: 'Amiri', serif;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .pdp-ingredients__card-image {
      width: 140px;
      height: 140px;
    }
  }
{%- endstyle -%}

<div class="pdp-ingredients section-{{ section.id }}-padding">
  {% render 'ritrue-section-styles', section: section %}
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.heading != blank -%}
      <h2 class="pdp-ingredients__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="pdp-ingredients__grid" role="list">
        {%- for block in section.blocks -%}
          <li
            class="pdp-ingredients__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="pdp-ingredients__card-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 400, 600, 800', sizes: '(min-width: 750px) 33vw, 75vw' }}
              {%- else -%}
                <div style="width:100%;height:100%;background:#F5F0E8;display:flex;align-items:center;justify-content:center;border-radius:50%;">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </div>
            <div class="pdp-ingredients__card-body">
              {%- if block.settings.badge != blank -%}
                <span class="pdp-ingredients__badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="pdp-ingredients__card-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="pdp-ingredients__card-text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP Ingredients",
  "class": "pdp-ingredients-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hero Ingredients"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge color",
      "default": "#56403F"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Custom background color"
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Custom background image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "min": 0,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 0
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Content font size",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "Key Ingredient"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Ingredient Name"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe the benefits of this ingredient."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Ingredients",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Moroccan Nila", "badge": "Hero" } },
        { "type": "ingredient", "settings": { "title": "Alpha Arbutin", "badge": "Brightening" } },
        { "type": "ingredient", "settings": { "title": "Niacinamide", "badge": "Barrier" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
