{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pdp-promo-banner {
    background: {{ section.settings.background_color }};
  }

  .pdp-promo-banners__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 2 }}, 1fr);
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .pdp-promo-banners__grid {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }
  }

  .pdp-promo-card {
    border-radius: 1.2rem;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    min-height: 14rem;
    padding: 2.4rem;
    transition: box-shadow 0.2s ease;
  }

  .pdp-promo-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .pdp-promo-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pdp-promo-card__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-promo-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .pdp-promo-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .pdp-promo-card__badge {
    display: inline-block;
    background: #E85A28;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 1rem;
    border-radius: 2rem;
    width: fit-content;
  }

  .pdp-promo-card__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .pdp-promo-card__subtitle {
    font-size: 1.3rem;
    margin: 0;
    opacity: 0.8;
  }

  .pdp-promo-card__code {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.15);
    border: 1px dashed currentColor;
    padding: 0.4rem 1.2rem;
    border-radius: 0.6rem;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    width: fit-content;
    opacity: 0.9;
  }
{%- endstyle -%}

<div class="pdp-promo-banner section-{{ section.id }}-padding">
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.blocks.size > 0 -%}
      <ul class="pdp-promo-banners__grid" role="list">
        {%- for block in section.blocks -%}
          <li
            class="pdp-promo-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            style="background: {{ block.settings.card_background }}; color: {{ block.settings.text_color }};"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }}; background: {{ block.settings.card_background }}; color: {{ block.settings.text_color }};"
            {% endif %}
          >
            {%- if block.settings.background_image != blank -%}
              <div class="pdp-promo-card__bg">
                {{ block.settings.background_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800' }}
              </div>
              <div class="pdp-promo-card__overlay" style="background: {{ block.settings.overlay_color }};"></div>
            {%- endif -%}

            <div class="pdp-promo-card__content">
              {%- if block.settings.badge != blank -%}
                <span class="pdp-promo-card__badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <p class="pdp-promo-card__title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p class="pdp-promo-card__subtitle">{{ block.settings.subtitle }}</p>
              {%- endif -%}
              {%- if block.settings.coupon_code != blank -%}
                <span class="pdp-promo-card__code">
                  Code: {{ block.settings.coupon_code }}
                </span>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP Promo Banner",
  "class": "pdp-promo-banner-section",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "Offer"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Buy 2 Get 4 Free"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "On all skincare products"
        },
        {
          "type": "text",
          "id": "coupon_code",
          "label": "Coupon code"
        },
        {
          "type": "color",
          "id": "card_background",
          "label": "Card background",
          "default": "#E8F5E9"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#1e1e1e"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "color_background",
          "id": "overlay_color",
          "label": "Image overlay"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Promo Banner",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "badge": "Offer",
            "title": "Buy 2 Get 4 Free",
            "subtitle": "On all skincare products",
            "card_background": "#E8F5E9"
          }
        },
        {
          "type": "banner",
          "settings": {
            "badge": "Save",
            "title": "Up to 20% Off",
            "subtitle": "Use code at checkout",
            "coupon_code": "GLOW20",
            "card_background": "#FFF39C"
          }
        }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
