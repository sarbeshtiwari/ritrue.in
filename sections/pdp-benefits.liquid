{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pdp-benefits {
    background: {{ section.settings.background_color }};
  }

  .pdp-benefits__heading {
    text-align: center;
    margin-bottom: 3.6rem;
    font-size: 2.4rem;
    font-weight: 600;
    color: #1e1e1e;
  }

  .pdp-benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .pdp-benefits__grid {
      grid-template-columns: 1fr;
      gap: 2.4rem;
    }
  }

  .pdp-benefits__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  .pdp-benefits__image-wrapper {
    width: {{ section.settings.image_size }}px;
    height: {{ section.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 1.6rem;
    border: 2px solid #eaeaea;
  }

  .pdp-benefits__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-benefits__image-placeholder {
    width: 100%;
    height: 100%;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp-benefits__image-placeholder svg {
    width: 40%;
    height: 40%;
    fill: #c7c7c7;
  }

  .pdp-benefits__card-title {
    font-size: 1.6rem;
    font-weight: 600;
    color: #1e1e1e;
    margin: 0 0 0.8rem;
    line-height: 1.3;
  }

  .pdp-benefits__card-text {
    font-size: 1.3rem;
    color: #737373;
    margin: 0;
    line-height: 1.5;
  }
{%- endstyle -%}

<div class="pdp-benefits section-{{ section.id }}-padding">
  <div class="page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.heading != blank -%}
      <h2 class="pdp-benefits__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="pdp-benefits__grid" role="list">
        {%- for block in section.blocks -%}
          <li
            class="pdp-benefits__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="pdp-benefits__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '150, 200, 300, 400', sizes: '(min-width: 750px) 200px, 150px' }}
              {%- else -%}
                <div class="pdp-benefits__image-placeholder">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="pdp-benefits__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="pdp-benefits__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP Benefits",
  "class": "pdp-benefits-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Helps With"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "image_size",
      "min": 80,
      "max": 200,
      "step": 10,
      "label": "Image size (px)",
      "default": 120
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Short description of this benefit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Tan Removal" } },
        { "type": "benefit", "settings": { "title": "Brightening" } },
        { "type": "benefit", "settings": { "title": "Hydration" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
