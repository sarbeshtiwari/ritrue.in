{{ 'ritrue-homepage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ritrue-animations.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign hero_product = section.settings.product
  if hero_product != blank
    assign hero_product_url = hero_product.url
  endif
  assign link_url = hero_product_url | default: section.settings.button_link
-%}

{% render 'ritrue-section-styles', section: section %}
<div id="home" class="ritrue-hero-banner">
  {%- if link_url != blank -%}
    <a href="{{ link_url }}">
  {%- endif -%}

  <picture>
    {%- if section.settings.mobile_image != blank -%}
      <source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 800 }}">
    {%- endif -%}

    {%- if section.settings.desktop_image != blank -%}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 1920 }}"
        alt="{{ section.settings.desktop_image.alt | default: 'RITRUE Banner' | escape }}"
        loading="eager"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.desktop_image.aspect_ratio | round }}"
        style="width:100%;height:auto;display:block;"
      >
    {%- elsif section.settings.mobile_image != blank -%}
      <img
        src="{{ section.settings.mobile_image | image_url: width: 1920 }}"
        alt="{{ section.settings.mobile_image.alt | default: 'RITRUE Banner' | escape }}"
        loading="eager"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.mobile_image.aspect_ratio | round }}"
        style="width:100%;height:auto;display:block;"
      >
    {%- else -%}
      <div style="width:100%;aspect-ratio:21/9;background:var(--ritrue-warm-bg,#F7F1E8);display:flex;align-items:center;justify-content:center;">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </picture>

  {%- if link_url != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "RITRUE Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Banner links to this product page."
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner Image",
      "info": "Recommended: 1920×900 or wider"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner Image",
      "info": "Recommended: 800×1000 (portrait)"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Banner Link (fallback)"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background Color",
      "info": "Leave empty to use default."
    },
    {
      "type": "image_picker",
      "id": "custom_bg_image",
      "label": "Background Image",
      "info": "Overrides background color when set."
    },
    {
      "type": "range",
      "id": "custom_min_height",
      "label": "Minimum Height (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 for auto height."
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "Content Font Size (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 to use default size."
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "RITRUE Hero Banner"
    }
  ]
}
{% endschema %}
