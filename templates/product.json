    "pdp_faq": {
      "type": "pdp-faq",
      "blocks": {
        "faq_1": {
          "type": "question",
          "settings": {
            "question": "What is the Moroccan Nila Glow Mask?",
            "answer": "<p>It's a 15-minute radiance ritual powered by authentic Moroccan Nila, Alpha Arbutin, and Niacinamide. The mask works to remove tan, even skin tone, and boost your natural glow — all in just one use.</p>"
          }
        },
        "faq_2": {
          "type": "question",
          "settings": {
            "question": "How do I use the mask?",
            "answer": "<p>Apply an even layer on clean, dry skin. Relax for 15 minutes, then rinse off with water. For best results, use 2-3 times per week. Always do a patch test before first use.</p>"
          }
        },
        "faq_3": {
          "type": "question",
          "settings": {
            "question": "Is it suitable for all skin types?",
            "answer": "<p>Yes! Our formula is dermatologically tested and suitable for all skin types — normal, oily, dry, combination, and sensitive. It's paraben-free, cruelty-free, and made with safe, skin-loving ingredients.</p>"
          }
        },
        "faq_4": {
          "type": "question",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>Most customers notice visible glow and brighter skin after just 1 use. For tan removal and even skin tone, consistent use over 2-4 weeks delivers the best results.</p>"
          }
        },
        "faq_5": {
          "type": "question",
          "settings": {
            "question": "Is COD (Cash on Delivery) available?",
            "answer": "<p>Yes, we offer Cash on Delivery across India. Prepaid orders enjoy free shipping as an added benefit.</p>"
          }
        },
        "faq_6": {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer hassle-free returns within 7 days of delivery. If you're not satisfied with the product, contact us at hello@ritrue.in or WhatsApp us at +91 99999 99999 for a quick resolution.</p>"
          }
        }
      },
